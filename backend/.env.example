PORT=3001

# Evolve gateway key — used for BOTH the cheap LLM calls (persona ceiling +
# task proposals, via the Anthropic-compatible gateway) AND the Evolve sandbox
# runs (cheapest model, haiku). Get one at https://dashboard.evolvingmachines.ai
EVOLVE_API_KEY=

# Optional: if set (sk-ant-...), cheap LLM calls go direct to Anthropic instead
# of the gateway. Leave blank to use the Evolve gateway.
ANTHROPIC_API_KEY=
